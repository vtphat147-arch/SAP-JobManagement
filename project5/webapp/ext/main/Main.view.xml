<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:f="sap.f" xmlns:macros="sap.fe.macros" xmlns:html="http://www.w3.org/1999/xhtml" controllerName="project5.ext.main.Main">
    <f:DynamicPage id="Main" headerExpanded="true">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>MainTitle}"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <macros:FilterBar id="FilterBar" metaPath="/JobList/@com.sap.vocabularies.UI.v1.SelectionFields#filterBarMacro3"/>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <macros:Table id="Table" metaPath="/JobList/@com.sap.vocabularies.UI.v1.LineItem#tableMacro2" filterBar="FilterBar" header="Background Jobs" isSearchable="false" type="ResponsiveTable" enableFullScreen="true" enableExport="true" selectionMode="Multi" variantManagement="Page">
                <macros:actions>
                    <Button text="Own Jobs" icon="sap-icon://world" type="Emphasized" press="onFilterOwnJobs"/>
                    <Button text="Job Log" icon="sap-icon://list" press="onShowJobLog"/>
                    <Button text="Create New Job" icon="sap-icon://add" type="Success" press="onCreateJob"/>
                </macros:actions>
            </macros:Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>